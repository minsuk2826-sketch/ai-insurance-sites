<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>보험사업설명회 초대</title>
  <meta name="description" content="지금 당신은 제2의 소득원을 준비하고 계신가요?">
  <meta name="theme-color" content="#f7fbff">

  <style>
    :root{
      --blue:#1769ff;
      --blue2:#0e52d8;
      --cyan:#21b8ef;
      --navy:#14213a;
      --text:#182338;
      --muted:#6c7890;
      --line:#dfe8f5;
      --soft:#f5f9ff;
      --yellow:#ffd84d;
      --white:#fff;
      --shadow:0 18px 50px rgba(48,88,145,.12);
      --radius:24px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Pretendard,-apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans KR",Arial,sans-serif;
      color:var(--text);
      background:#fff;
      line-height:1.55;
    }
    a{text-decoration:none;color:inherit}
    button,input,select{font:inherit}
    .wrap{width:min(1120px,calc(100% - 28px));margin:0 auto}

    .topbar{
      position:sticky;top:0;z-index:30;
      background:rgba(255,255,255,.94);
      backdrop-filter:blur(14px);
      border-bottom:1px solid rgba(49,86,142,.08);
    }
    .topbar .inner{
      height:62px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:18px;
    }
    .brand{font-weight:900;letter-spacing:-.04em}
    .brand strong{color:var(--blue)}
    .top-link{
      padding:9px 14px;
      border-radius:999px;
      border:1px solid var(--line);
      background:#fff;
      font-size:14px;
      font-weight:800;
    }

    .hero{
      background:
        radial-gradient(circle at 82% 28%,rgba(23,105,255,.13),transparent 28%),
        radial-gradient(circle at 15% 18%,rgba(34,184,240,.11),transparent 22%),
        linear-gradient(180deg,#f8fbff 0%,#ffffff 100%);
      overflow:hidden;
    }
    .hero-inner{
      min-height:585px;
      display:grid;
      grid-template-columns:1.02fr .98fr;
      gap:44px;
      align-items:center;
      padding:34px 0 52px;
    }
    .hero-copy{text-align:center}
    .hero-brand{
      color:var(--blue);
      font-weight:900;
      font-size:28px;
      letter-spacing:-.04em;
      margin-bottom:2px;
    }
    .hero-subbrand{
      color:#2d3e5d;
      font-weight:800;
      margin-bottom:20px;
    }
    .hero h1{
      margin:0;
      font-size:clamp(50px,6.4vw,82px);
      line-height:1.03;
      letter-spacing:-.065em;
    }
    .hero h1 em{font-style:normal;color:var(--blue)}
    .hero .sub{
      margin:19px 0 7px;
      font-size:22px;
      font-weight:900;
    }
    .hero .desc{
      margin:0 0 26px;
      color:var(--muted);
      font-size:17px;
    }
    .hero-actions{
      display:flex;
      justify-content:center;
      gap:12px;
      flex-wrap:wrap;
    }
    .btn{
      min-height:56px;
      padding:0 24px;
      border-radius:15px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:9px;
      font-weight:900;
      box-shadow:0 10px 28px rgba(23,105,255,.12);
    }
    .btn.blue{color:#fff;background:linear-gradient(135deg,var(--blue),var(--blue2))}
    .btn.kakao{background:var(--yellow);color:#1f2937}
    .hero-bullets{
      margin-top:22px;
      display:flex;
      justify-content:center;
      flex-wrap:wrap;
      gap:17px;
      color:#52617a;
      font-size:14px;
      font-weight:800;
    }

    .phone-wrap{display:flex;justify-content:center}
    .phone{
      width:min(390px,100%);
      border-radius:38px;
      padding:18px;
      background:#fff;
      border:1px solid #dce7f6;
      box-shadow:0 26px 70px rgba(57,90,142,.18);
      transform:rotate(2deg);
    }
    .notch{width:112px;height:20px;border-radius:999px;background:#162036;margin:0 auto 18px}
    .phone-title{text-align:center;font-size:20px;font-weight:900;margin-bottom:16px}
    .score-box{
      border-radius:26px;
      padding:22px;
      background:linear-gradient(180deg,#f8fbff,#eef5ff);
      border:1px solid #dce8f7;
    }
    .score-main{display:grid;grid-template-columns:155px 1fr;gap:18px;align-items:center}
    .ring{
      width:155px;aspect-ratio:1;border-radius:50%;
      background:conic-gradient(var(--blue) 0 72%,#e6edf7 72% 100%);
      padding:14px;display:grid;place-items:center;
    }
    .ring-inner{
      width:100%;height:100%;border-radius:50%;
      background:#fff;display:grid;place-items:center;text-align:center;
      box-shadow:inset 0 0 0 1px #e8eef7;
    }
    .ring strong{font-size:48px;line-height:1}
    .ring small{color:var(--blue);font-weight:900}
    .bars{display:grid;gap:11px}
    .bar-row{display:grid;grid-template-columns:82px 1fr 34px;gap:8px;align-items:center;font-size:13px}
    .bar{height:8px;background:#e8eef7;border-radius:999px;overflow:hidden}
    .bar i{display:block;height:100%;background:linear-gradient(90deg,var(--cyan),var(--blue));border-radius:999px}
    .ai-note{
      margin-top:16px;background:#fff;border:1px solid #e2eaf5;border-radius:16px;
      padding:14px;font-size:13px;color:#5b6880;
    }

    section{padding:80px 0}
    .section-title{text-align:center;margin-bottom:36px}
    .section-title h2{
      margin:0 0 10px;
      font-size:clamp(31px,4vw,47px);
      letter-spacing:-.055em;
      line-height:1.15;
    }
    .section-title p{margin:0;color:var(--muted);font-size:18px}

    .questions{background:var(--soft)}
    .card-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
    .soft-card{
      background:#fff;border:1px solid var(--line);border-radius:20px;padding:24px 16px;
      text-align:center;box-shadow:0 8px 24px rgba(52,91,144,.06);
    }
    .soft-card .ico{font-size:33px;margin-bottom:12px}
    .soft-card b{display:block;font-size:16px}

    .analysis-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:22px}
    .panel{
      background:#fff;border:1px solid var(--line);border-radius:24px;padding:30px;box-shadow:var(--shadow);
    }
    .panel h3{margin:0 0 22px;font-size:25px}
    .mini-score{display:grid;grid-template-columns:190px 1fr;gap:26px;align-items:center}
    .mini-score .ring{width:190px}
    .question-panel{
      background:linear-gradient(145deg,#f8fbff,#edf4ff);
      display:flex;flex-direction:column;justify-content:center;
    }
    .question-mark{
      width:56px;height:56px;border-radius:50%;background:var(--blue);color:#fff;
      display:grid;place-items:center;font-size:31px;font-weight:900;margin-bottom:16px;
    }
    .question-panel h3{font-size:34px;line-height:1.35;letter-spacing:-.05em}
    .question-panel strong{color:var(--blue)}

    .features-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
    .feature{
      border:1px solid var(--line);border-radius:20px;padding:24px 16px;text-align:center;background:#fff;
    }
    .feature .ico{font-size:31px;margin-bottom:12px}
    .feature b{display:block;margin-bottom:7px}
    .feature span{font-size:14px;color:var(--muted)}

    .cases{background:var(--soft)}
    .case-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
    .case{
      background:#fff;border:1px solid var(--line);border-radius:24px;padding:28px;box-shadow:var(--shadow)
    }
    .tag{
      display:inline-block;padding:6px 10px;border-radius:999px;background:#e9f2ff;
      color:#1658bd;font-size:13px;font-weight:900;
    }
    .case h3{margin:14px 0 20px}
    .change{
      display:flex;justify-content:center;align-items:center;gap:20px;
      font-size:38px;font-weight:900;color:#17386f;
    }
    .change .arrow{color:var(--blue)}
    .case-note{margin-top:18px;color:#687790;font-size:14px;text-align:center}

    .steps{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
    .step{text-align:center;position:relative}
    .step-circle{
      width:78px;height:78px;border-radius:50%;margin:0 auto 14px;
      display:grid;place-items:center;border:1px solid var(--line);background:#fff;
      box-shadow:0 10px 24px rgba(51,90,143,.08);font-size:30px;
    }
    .step small{display:block;color:var(--blue);font-weight:900}
    .step b{display:block}
    .step:not(:last-child)::after{
      content:"→";position:absolute;right:-10px;top:26px;color:#90a8cb;font-size:22px;
    }

    .trust{
      background:#fff;
      padding-top:12px;
    }
    .trust-box{
      border:1px solid var(--line);
      border-radius:22px;
      background:linear-gradient(135deg,#f8fbff,#ffffff);
      padding:26px;
      text-align:center;
      box-shadow:0 12px 35px rgba(48,88,145,.08);
    }
    .trust-box strong{color:var(--blue)}

    .apply{background:linear-gradient(180deg,#eff6ff,#fff)}
    .apply-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:24px;align-items:stretch}
    .apply-copy{
      border:1px solid var(--line);border-radius:24px;padding:34px;
      background:linear-gradient(135deg,#eaf3ff,#fbfdff);
    }
    .apply-copy h2{font-size:40px;line-height:1.2;letter-spacing:-.05em;margin:0 0 18px}
    .apply-copy em{font-style:normal;color:var(--blue)}
    .apply-copy ul{list-style:none;padding:0;margin:0;color:#4d5c76}
    .apply-copy li{margin:12px 0}

    .form-card{
      background:#fff;border:1px solid var(--line);border-radius:24px;padding:30px;box-shadow:var(--shadow);
    }
    .form-card h3{text-align:center;font-size:25px;margin:0 0 20px}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    input,select{
      width:100%;height:52px;border:1px solid #d7e1ef;border-radius:12px;
      padding:0 14px;outline:none;background:#fff;
    }
    input:focus,select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(23,105,255,.1)}
    .full{grid-column:1/-1}
    .agree{display:flex;gap:9px;align-items:flex-start;font-size:13px;color:#687790}
    .agree input{width:18px;height:18px;margin-top:2px}
    .submit{
      height:56px;border:0;border-radius:12px;
      background:linear-gradient(135deg,var(--blue),var(--blue2));
      color:#fff;font-weight:900;cursor:pointer;
    }
    .contact-row{display:flex;gap:10px;margin-top:12px}
    .contact-row a{flex:1;text-align:center;padding:13px;border-radius:12px;font-weight:900}
    .contact-row .call{background:#edf4ff;color:#22477f}
    .contact-row .kakao{background:var(--yellow);color:#1f2937}

    footer{
      padding:28px 0;border-top:1px solid var(--line);
      color:#74829a;font-size:13px;text-align:center;
    }

    @media(max-width:920px){
      .hero-inner,.analysis-grid,.apply-grid{grid-template-columns:1fr}
      .hero-inner{min-height:auto;padding:38px 0 58px}
      .card-grid,.features-grid{grid-template-columns:repeat(2,1fr)}
      .steps{grid-template-columns:repeat(2,1fr)}
      .step:not(:last-child)::after{display:none}
      .case-grid{grid-template-columns:1fr}
      .phone{max-width:430px}
    }
    @media(max-width:620px){
      .wrap{width:min(100% - 22px,1120px)}
      .topbar .inner{height:58px}
      .top-link{font-size:12px;padding:8px 10px}
      .hero-inner{padding-top:24px}
      .hero-brand{font-size:23px}
      .hero-subbrand{margin-bottom:14px}
      .hero h1{font-size:48px}
      .hero .sub{font-size:18px}
      .score-main,.mini-score{grid-template-columns:1fr}
      .ring{margin:auto}
      .card-grid,.features-grid,.steps{grid-template-columns:1fr}
      section{padding:62px 0}
      .form-grid{grid-template-columns:1fr}
      .full{grid-column:auto}
      .contact-row{flex-direction:column}
      .change{font-size:29px}
      .apply-copy h2{font-size:33px}
    }
  
  /* Mobile header fix */
  .topbar .inner{
    justify-content:center !important;
  }
  .brand{
    width:100%;
    text-align:center;
    white-space:nowrap;
  }
  @media(max-width:620px){
    .topbar .inner{
      height:54px !important;
      padding-left:6px;
      padding-right:6px;
    }
    .brand{
      font-size:14px !important;
      letter-spacing:-0.05em;
      overflow:hidden;
      text-overflow:ellipsis;
    }
  }


  /* Final mobile hero spacing */
  .hero h1{ margin-top:0 !important; }
  @media(max-width:620px){
    .hero-inner{ padding-top:18px !important; }
    .hero-copy{ padding-top:0 !important; }
  }


  .completion-page{
    min-height:100vh;display:none;align-items:center;justify-content:center;
    padding:34px 18px;background:linear-gradient(180deg,#f1f7ff 0%,#ffffff 100%);
  }
  .completion-card{
    width:min(560px,100%);background:#fff;border:1px solid var(--line);border-radius:28px;
    padding:42px 28px;text-align:center;box-shadow:var(--shadow);
  }
  .completion-icon{
    width:82px;height:82px;border-radius:50%;display:grid;place-items:center;margin:0 auto 22px;
    background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-size:40px;font-weight:900;
  }
  .completion-card h2{margin:0 0 14px;font-size:34px;letter-spacing:-.05em;line-height:1.2}
  .completion-card .lead{margin:0;color:#55657d;font-size:18px;line-height:1.7}
  .receipt-box{margin:24px 0;padding:16px;border-radius:16px;background:#f3f7fd;color:#42536d}
  .receipt-box strong{display:block;margin-top:4px;color:var(--blue);font-size:20px;letter-spacing:.02em}
  .completion-guide{margin:22px 0;text-align:left;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:20px 4px}
  .completion-guide b{display:block;margin-bottom:10px}
  .completion-guide p{margin:7px 0;color:#64738a}
  .completion-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .completion-actions a{padding:15px 12px;border-radius:13px;font-weight:900}
  .completion-actions .call{background:#edf4ff;color:#22477f}
  .completion-actions .kakao{background:var(--yellow);color:#1f2937}
  @media(max-width:520px){
    .completion-card{padding:34px 20px}.completion-card h2{font-size:29px}.completion-actions{grid-template-columns:1fr}
  }

</style>

